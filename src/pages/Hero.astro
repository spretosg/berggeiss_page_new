<style>
  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
  }

  .menu {
    display: none;
    flex-direction: column;
    gap: 1rem;
  }

  .menu.open {
    display: flex;
  }

  .hamburger {
    font-size: 1.5rem;
    cursor: pointer;
    background: none;
    border: none;
  }

  @media (min-width: 768px) {
    .menu {
      display: flex !important;
      flex-direction: row;
    }

    .hamburger {
      display: none;
    }
  }
</style>

<nav class="nav">
  <div>MySite</div>

  <button class="hamburger" id="menu-btn">☰</button>

  <div class="menu" id="menu">
    <a href="/">Home</a>
    <a href="/der_lauf">Strecken</a>
    <a href="/about">Ueber uns</a>
    <a href="/results">Resultate</a>
  </div>
</nav>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('menu');

  btn.addEventListener('click', () => {
    menu.classList.toggle('open');
  });
</script>