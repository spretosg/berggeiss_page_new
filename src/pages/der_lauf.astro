---
import Layout from "../layouts/Layout.astro";
const base = import.meta.env.BASE_URL;


const courses = [
  {
    name: "Berggitzi",
    distance: "2.75 km",
    alti: "+130",
    start: "18.30 Uhr - Braunwald Rehaklinik",
    cat: "U12, U14, U16, Run for Fun (keine Rangliste) ",
    color: "#008330",
    map: `/berggeiss_page_new/img/berggitzi_strecke.png`,
    elevation: `/berggeiss_page_new/img/berggitzi_profile.png`,
    slug: "/berggeiss_page_new/berggitzi",
    Kondition: "❤️",
    Technik: "🏃",
  },
  {
    name: "Klassiker",
    distance: "5.5 km",
    alti: "+660",
    start: "18.30 Uhr - Linthal Braunwaldbahn",
    cat: "M/W16-34, M/W35-49, M/W 50+ (U16 wird in M/16-34 gewertet)",
    color: "#0049e6",
    map: `/berggeiss_page_new/img/klas_strecke.png`,
    elevation: `/berggeiss_page_new/img/klass_profile.png`,
    slug: "/berggeiss_page_new/klassiker",
    Kondition: "❤️❤️",
    Technik: "🏃🏃",
  },
  {
    name: "Belvedere",
    distance: "12.6 km",
    alti: "+1200",
    start: "18.30 Uhr - Linthal Braunwaldbahn",
    cat: "M/W16-34, M/W35-49, M/W 50+ (U16 wird in M/16-34 gewertet)",
    color: "#fa1d1d",
    map: `/berggeiss_page_new/img/bel_strecke.png`,
    elevation: `/berggeiss_page_new/img/bel_profile.png`,
    slug: "/berggeiss_page_new/belvedere",
    Kondition: "❤️❤️❤️",
    Technik: "🏃🏃🏃🏃",

  }
];
---

<Layout title="Strecken" image="/img/hero.jpg">

<section class="hero">
  <h1>Finde die perfekte Herausforderung für dich</h1>
</section>

<div class="grid">
  {courses.map(course => (
    <div class="card">
      
<div class="card-header" style={`background:${course.color}`}>
  <h2>{course.name}</h2>

  <div class="meta">
    <span class="badge">{course.distance} · {course.alti} Hm</span>
    <br></br>
    <span class="start">Start: {course.start}</span>
  </div>
</div>

      <div class="card-body">

        <img src={course.map} alt="Karte" class="preview" />
        <span class="start">Kategorien: {course.cat}</span>
      </div>

      <div class="card-actions">
        <a href={course.slug} class="btn secondary">
          Details
        </a>
         <ul class="race-stats">
            <li>Kondition: {course.Kondition}</li>
            <li>Technik: {course.Technik}</li>
        </ul>
      </div>

    </div>
  ))}
</div>

<section class="info">

  <section class="hero">
  <h1>Weitere wichtige Informationen</h1>
</section>

<div class="tabs">

  <!-- TAB BUTTONS -->
  <div class="tab-buttons">
    <button class="tab-btn active" onclick="openTab(event, 'kategorien')">Kategorien / Startgeld</button>
    <button class="tab-btn" onclick="openTab(event, 'programm')">Programm</button>
    <button class="tab-btn" onclick="openTab(event, 'gepaeck')">Gepäck</button>
    <button class="tab-btn" onclick="openTab(event, 'garderoben')">Garderoben</button>
    <button class="tab-btn" onclick="openTab(event, 'sicherheit')">Sicherheit</button>
    <button class="tab-btn" onclick="openTab(event, 'reglement')">Reglement</button>
  </div>

  <!-- TAB CONTENT -->

  <div id="programm" class="tab-content">
    <h3>Programm</h3>
    <p><strong>Startnummernausgabe:</strong> ab 16:00 Linthal Braunwaldbahnen (Belvedere und Klassiker bis 5min vor dem Start, Berggitzi bis 17.50)</p>
    <p><strong>Zielschluss:</strong> 19:45 Hüttenberg (Hotel Cristal)</p>
    <p><strong>Rückreise:</strong> 20:25 · 20:55 · 21:25 · 21:55</p>
  </div>

  <div id="gepaeck" class="tab-content">
    <h3>Gepäcktransport</h3>
    <ul>
      <li><strong>Abgabe:</strong> Bis 10min vor dem Start</li>
      <li><strong>Ziel:</strong> Hüttenberg beim Hotel Cristal</li>
    </ul>
  </div>

  <div id="garderoben" class="tab-content">
    <h3>Garderoben & Toiletten</h3>
    <ul>
      <li>❌ Keine Garderoben am Start</li>
      <li>✅ Toiletten an der Talstation</li>
      <li>✅ Toiletten im Ziel</li>
      <li>❌ Keine Duschen im Ziel</li>
    </ul>
  </div>

  <div id="kategorien" class="tab-content active">
    <h3>Kategorien & Startgeld</h3>

    <ul>
      <li>U12: 2015 und jünger</li>
      <li>U14: 2014 – 2013</li>
      <li>U16: 2012 – 2011</li>
      <li>W/M16-34: 2010 – 1992</li>
      <li>W/M35-49: 1991 – 1977</li>
      <li>W/M50+: 1976 und älter</li>
    </ul>

    <!-- STARTGELD -->
  <h3>Startgeld</h3>

  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>Zeitraum</th>
          <th>Klassiker</th>
          <th>Belvedere</th>
          <th>Berggitzi (Run for Fun) </th>
          <th>Berggitzi (U16,U14,U12) </th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>01.04.–11.08.</td>
          <td>35.-</td>
          <td>40.-</td>
          <td>30.-</td>
          <td>10.-</td>
        </tr>
        <tr>
          <td>Nachmeldung</td>
          <td>40.-</td>
          <td>45.-</td>
          <td>35.-</td>
          <td>10.-</td>
        </tr>
      </tbody>
    </table>
  </div>

    <h3>Preise</h3>
    <ul>
      <li>Finishergeschenk für alle</li>
      <li>Top 3 in Wertungskategorien</li>
    </ul>
  </div>

  <div id="sicherheit" class="tab-content">
    <h3>Sicherheit & Sanität</h3>
    <ul>
      <li>Schlussläufer auf Strecke</li>
      <li>Streckenposten</li>
      <li>2 Ärzte + 1 Notfallsanitäter</li>
    </ul>
    <p><strong>❗ Bei Bedarf ist Hilfeleistung durch Teilnehmer:Innen Pflicht</strong></p>
  </div>

</div>

  <div id="reglement" class="tab-content">
    <h3>Reglement</h3>
    <iframe
    src="/berggeiss_page_new/img/Wettkampfreglement_Berggeiss_25.pdf"
    height="400"
    style="width:100%; border-radius:12px;"
  ></iframe>
  </div>

</div>

  

</section>

</Layout>

<style>
.grid {
  display: grid;
  gap: 1.5rem;
}


/* Desktop */
@media (min-width: 768px) {
  .grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

.card {
  border-radius: 16px;
  overflow: hidden;
  background: white;
  box-shadow: 0 8px 20px rgba(0,0,0,0.08);
  display: flex;
  flex-direction: column;
}

.card-header {
  padding: 1rem;
  color: white;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-body {
  padding: 1rem;
}

.preview {
  width: 100%;
  border-radius: 8px;
  margin-top: 0.5rem;
}

.elevation {
  width: 100%;
  margin-top: 0.5rem;
  opacity: 0.8;
}

.card-actions {
  display: flex;
  gap: 0.5rem;
  padding: 1rem;
  margin-top: auto;
}

.btn {
  flex: 1;
  text-align: center;
  padding: 0.6rem;
  border-radius: 8px;
  text-decoration: none;
  font-weight: bold;
}

.btn.primary {
  background: black;
  color: white;
}

.btn.secondary {

  padding: 12px 24px;
  font-size: 15px;
  font-weight: 600;
  border-radius: 6px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-align: center;

  background-color: transparent;
  color: #2c2c2c;

  border: 2px solid #2c2c2c;
  transition: all 0.25s ease;
}

.btn.secondary:hover {
  background-color: #2c2c2c;
  color: #ffffff;
  border-color: #2c2c2c;
}

/* TAB BUTTONS */
.tab-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 1rem;
}

.tab-btn {
  border: none;
  padding: 0.5rem 1rem;
  border-radius: 999px;
  background: #eee;
  cursor: pointer;
  font-weight: 600;
  transition: 0.2s;
}

.tab-btn:hover {
  background: #ddd;
}

.tab-btn.active {
  background: black;
  color: white;
}

/* TAB CONTENT */
.tab-content {
  display: none;
  background: #f9fafb;
  padding: 1rem;
  border-radius: 12px;
}

.tab-content.active {
  display: block;
}

.table-wrapper {
  overflow-x: auto;              /* 👈 mobile scroll */
  margin-top: 1.5rem;
}

/* TABLE BASE */
table {
  width: 100%;
  border-collapse: collapse;
  background: white;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 8px 20px rgba(0,0,0,0.06);
}

/* HEADER */
thead {
  background: #111;
  color: white;
}

th {
  padding: 0.8rem;
  font-weight: 600;
  text-align: left;
  font-size: 0.9rem;
}

/* BODY */
td {
  padding: 0.8rem;
  border-bottom: 1px solid #eee;
  font-size: 0.95rem;
}

/* STRIPES */
tbody tr:nth-child(even) {
  background: #f9fafb;
}

/* HOVER */
tbody tr:hover {
  background: #f1f5f9;
}

/* FIRST COLUMN (labels) */
td:first-child {
  font-weight: 600;
  color: #444;
}

/* RESPONSIVE TEXT */
@media (max-width: 600px) {
  th, td {
    padding: 0.6rem;
    font-size: 0.85rem;
  }
}
</style>

<script is:inline>
  function openTab(event, tabId) {
    document.querySelectorAll(".tab-content").forEach(el => {
      el.classList.remove("active");
    });

    document.querySelectorAll(".tab-btn").forEach(el => {
      el.classList.remove("active");
    });

    document.getElementById(tabId).classList.add("active");
    event.currentTarget.classList.add("active");
  }
</script>
