---
const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>

  <body>
    <style>
      body {
        margin: 0;
        font-family: system-ui, sans-serif;
        background: #f7f7f7;
        color: #1a1a1a;
      }

      /* HEADER */
      .header {
        position: absolute;
        top: 10px;
        left: 0;
        width: 90%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 2rem;
        z-index: 10;
      }

      .nav-btn {
        color: white;
        text-decoration: none;
        font-weight: 600;
        padding: 0.5rem 1rem;
        border-radius: 999px;
        background: rgba(0,0,0,0.4);
        backdrop-filter: blur(6px);
        transition: all 0.2s ease;
      }

      .nav-btn:hover {
        background: rgba(0,0,0,0.6);
      }

      /* HERO */
.hero {
  background-image: url('/img/hero_img.jpg');
  width: 100%;
  height: 200px;
  background-position: top;
  background-repeat: no-repeat;
  background-size: cover !important;   /* 👈 force it */


  display: flex;
  align-items: center;
  justify-content: center;

  text-align: center;
  padding: 2rem 1rem;
}

.hero h1 {
  font-size: clamp(2rem, 5vw, 3rem);
  background: rgba(0,0,0,0.5);
  color: white;
  padding: 1.2rem 2.5rem;
  border-radius: 12px;

  margin: 0;                 /* reset default */
}



      /* CONTENT */
      .content {
        max-width: 90%;
        margin: -10px auto 2rem;
        padding: 2rem;
        background: white;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
      }

      @media (max-width: 600px) {
        .header {
          padding: 1rem;
        }

        .content {
          margin: -40px 1rem 2rem;
          padding: 1.5rem;
        }
      }

      /* FOOTER */
.footer {
  background: #111;
  color: white;
  padding: 3rem 1rem;
  margin-top: 3rem;
  text-align: center;
}

.sponsor-section {
  margin-bottom: 2rem;
}

.sponsor-section h3 {
  margin-bottom: 1rem;
}

/* GRID */
.sponsors {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 1.5rem;
}

/* LOGOS */
.sponsors img {
  height: 50px;
  object-fit: contain;
  filter: brightness(0) invert(1); /* white logos */
  opacity: 0.8;
  transition: 0.2s;
}

.sponsors img:hover {
  opacity: 1;
  transform: scale(1.05);
}

/* SIZE HIERARCHY */
.sponsors.gold img {
  height: 70px;
}

.sponsors.silver img {
  height: 55px;
}

.sponsors.supporter img {
  height: 40px;
}
    </style>

    <!-- HEADER -->
    <div class="header">
      <a href={`${base}`} class="nav-btn">🏠 Home</a>
      <a href={`${base}contact`} class="nav-btn">Kontakt</a>
    </div>

    <!-- HERO -->
    <div class="hero">
      <h1>{title}</h1>
    </div>

    <!-- CONTENT -->
    <div class="content">
      <slot />
    </div>

    <!-- FOOTER -->
<footer class="footer">

  <div class="sponsor-section">
    <h3>Gold Sponsoren</h3>
    <div class="sponsors gold">
      <img src={`${base}img/sponsor1.png`} />
      <img src={`${base}img/sponsor1.png`} />
    </div>
  </div>

  <div class="sponsor-section">
    <h3>Silber Sponsoren</h3>
    <div class="sponsors silver">
      <img src={`${base}img/sponsor2.png`} />
      <img src={`${base}img/sponsor2.png`} />
    </div>
  </div>

  <div class="sponsor-section">
    <h3>Unterstützer</h3>
    <div class="sponsors supporter">
      <img src={`${base}img/sponsor3.png`} />
      <img src={`${base}img/sponsor3.png`} />
    </div>
  </div>

</footer>

  </body>
</html>